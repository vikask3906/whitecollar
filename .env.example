# ─────────────────────────────────────────────────────────────────────────────
#  ADRC — Environment Variables Template
#  Copy this file to .env and fill in your values.
#  NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ─── PostgreSQL ───────────────────────────────────────────────────────────────
POSTGRES_USER=adrc_user
POSTGRES_PASSWORD=adrc_pass
POSTGRES_DB=adrc_db
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Async SQLAlchemy connection URL (used by FastAPI)
DATABASE_URL=postgresql+asyncpg://adrc_user:adrc_pass@localhost:5432/adrc_db

# Sync connection URL (used by Alembic CLI only)
SYNC_DATABASE_URL=postgresql+psycopg2://adrc_user:adrc_pass@localhost:5432/adrc_db

# ─── Twilio ───────────────────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_PHONE_NUMBER=+1415xxxxxxx         # Your Twilio sender number

# ─── Azure OpenAI ─────────────────────────────────────────────────────────────
AZURE_OPENAI_ENDPOINT=https://YOUR_RESOURCE.openai.azure.com/
AZURE_OPENAI_API_KEY=your_azure_openai_key
AZURE_OPENAI_DEPLOYMENT=gpt-4o

# ─── Azure AI Content Safety ──────────────────────────────────────────────────
AZURE_CONTENT_SAFETY_ENDPOINT=https://YOUR_RESOURCE.cognitiveservices.azure.com/
AZURE_CONTENT_SAFETY_KEY=your_content_safety_key

# ─── Azure AI Search ──────────────────────────────────────────────────────────
AZURE_SEARCH_ENDPOINT=https://YOUR_SEARCH.search.windows.net
AZURE_SEARCH_KEY=your_search_admin_key
AZURE_SEARCH_INDEX=ndma-sops

# ─── App Settings ─────────────────────────────────────────────────────────────
APP_ENV=development
LOG_LEVEL=DEBUG

# Clustering thresholds for Trusted Node verification
CLUSTER_RADIUS_METERS=500
CLUSTER_TIME_WINDOW_MINUTES=30
CLUSTER_MIN_REPORTS=3
